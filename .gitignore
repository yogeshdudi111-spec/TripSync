# Example .gitignore files: https://github.com/github/gitignore
/bower_components/
/node_modules/
backend/node_modules/
# Database
*.sqlite
*.db

# Environment variables (if you create a .env file later)
.env

# OS generated files
.DS_Store
# Ignore node_modules inside the backend folder
backend/node_modules/

# Ignore sqlite databases inside the backend folder
backend/*.sqlite
backend/*.db